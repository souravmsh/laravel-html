{
    "name": "souravmsh/laravel-html",
    "description": "HTML and Form Builders for Laravel",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "html-form",
        "html",
        "form",
        "contact",
        "builder",
        "souravmsh",
        "codekernel"
    ],
    "authors": [
        {
            "name": "Shohrab Hossain",
            "email": "sourav.diubd@gmail.com",
            "homepage": "https://github.com/souravmsh",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Souravmsh\\Html\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Souravmsh\\Html\\HtmlServiceProvider"
            ],
            "aliases": {
                "Form": "Souravmsh\\Html\\Facades\\Form"
            }
        }
    },
    "support": {
        "issues": "https://github.com/souravmsh/laravel-html/issues",
        "source": "https://github.com/souravmsh/laravel-html"
    }
}
